# Django
SECRET_KEY=change-me-to-a-random-string
# 32-byte hex-encoded pepper for HMAC-SHA256 password hashing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PASSWORD_PEPPER=change-me-to-a-64-char-hex-string
# Fernet key for encrypting the email field at rest in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENCRYPTION_KEY=change-me-to-a-fernet-key
# HMAC pepper for the email blind index used for lookups and uniqueness checks.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EMAIL_BLIND_INDEX_PEPPER=change-me-to-a-64-char-hex-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
# Local Postgres via docker-compose (recommended):
DATABASE_URL=postgres://pleskal:pleskal@localhost:5432/pleskal
# SQLite fallback (search won't work on SQLite):
# DATABASE_URL=sqlite:///db.sqlite3

# Cloudflare R2 (optional, for production image storage)
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# CDN_DOMAIN=cdn.yourdomain.com

# Railway (set automatically by Railway, no need to set manually)
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# Custom domain CSRF trusted origins (comma-separated, with https://)
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Sentry (optional)
# SENTRY_DSN=

# Email
# In development (DEBUG=true) emails are printed to the terminal.
# In production emails are sent via Resend (django-anymail[resend]).
# RESEND_API_KEY=
DEFAULT_FROM_EMAIL=Pleskal <noreply@pleskal.dk>
SERVER_EMAIL=Pleskal <noreply@pleskal.dk>
# Comma-separated email addresses for error emails & signup alerts:
#   ADMINS=alice@example.com,bob@example.com
# ADMINS=
