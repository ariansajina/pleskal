# Django
SECRET_KEY=change-me-to-a-random-string
# 32-byte hex-encoded pepper for HMAC-SHA256 password hashing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PASSWORD_PEPPER=change-me-to-a-64-char-hex-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
# Local Postgres via docker-compose (recommended):
DATABASE_URL=postgres://pleskal:pleskal@localhost:5432/pleskal
# SQLite fallback (search won't work on SQLite):
# DATABASE_URL=sqlite:///db.sqlite3

# Cloudflare R2 (optional, for production image storage and database backups)
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# CDN_DOMAIN=cdn.yourdomain.com
# DB_BACKUP_RETENTION_DAYS=30 (how many days to keep database backups, default: 30)

# Railway (set automatically by Railway, no need to set manually)
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# Custom domain CSRF trusted origins (comma-separated, with https://)
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Sentry (optional)
# SENTRY_DSN=

# Email
# Set RESEND_API_KEY to send real emails via Resend in any environment.
# Without it, dev falls back to console backend (prints to terminal).
# RESEND_API_KEY=
# Resend segment ID — when set, verified users are added to this segment after contact creation.
# RESEND_SEGMENT_ID=
# Use onboarding@resend.dev for testing (Resend shared domain, no domain verification needed).
# Switch to your verified domain in production, e.g. noreply@pleskal.dk
DEFAULT_FROM_EMAIL=pleskal <onboarding@resend.dev>
SERVER_EMAIL=pleskal <onboarding@resend.dev>
# Comma-separated email addresses for error emails & signup alerts:
#   ADMINS=alice@example.com,bob@example.com
# ADMINS=

# allauth
SITE_DOMAIN=localhost:8000
SITE_NAME=pleskal

# Geocoding (OpenStreetMap / Nominatim)
# Defaults to disabled in DEBUG=true so local dev never hits Nominatim unexpectedly.
# Set to true locally if you want to exercise the geocoding path.
# GEOCODING_ENABLED=false
# Descriptive User-Agent sent with every Nominatim request (their policy requires one).
# GEOCODING_USER_AGENT=pleskal/1.0 (https://pleskal.dk; contact via github.com/ariansajina/pleskal)

# Scraper enable/disable (all enabled by default; set to false/0/no/off to disable)
# SCRAPER_DANSEHALLERNE_ENABLED=true
# SCRAPER_DANSEHALLERNE_WORKSHOPS_ENABLED=true
# SCRAPER_HAUTSCENE_ENABLED=true
# SCRAPER_SYDHAVNTEATER_ENABLED=true
# SCRAPER_TOASTERCPH_ENABLED=true
# SCRAPER_KBHDANSER_ENABLED=true
