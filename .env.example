# Django
SECRET_KEY=change-me-to-a-random-string
# 32-byte hex-encoded pepper for HMAC-SHA256 password hashing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PASSWORD_PEPPER=change-me-to-a-64-char-hex-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
# Local Postgres via docker-compose (recommended):
DATABASE_URL=postgres://pleskal:pleskal@localhost:5432/pleskal
# SQLite fallback (search won't work on SQLite):
# DATABASE_URL=sqlite:///db.sqlite3

# Cloudflare R2 (optional, for production image storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=

# Sentry (optional)
# SENTRY_DSN=

# Email (production only; dev uses console backend)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
